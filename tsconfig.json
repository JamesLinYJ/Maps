{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@maps/api/*": ["apps/api/src/*"],
      "@maps/compliance": ["packages/compliance/src/index.ts"],
      "@maps/llm-core": ["packages/llm-core/src/index.ts"],
      "@maps/map-core": ["packages/map-core/src/index.ts"],
      "@maps/observability": ["packages/observability/src/index.ts"],
      "@maps/schemas": ["packages/schemas/src/index.ts"],
      "@maps/tools": ["packages/tools/src/index.ts"],
      "@maps/ui": ["packages/ui/src/index.tsx"],
      "@maps/voice-core": ["packages/voice-core/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
