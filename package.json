{
  "name": "maps",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "python -m uvicorn apps.backend.app.main:app --reload",
    "dev:web": "vite --config vite.config.ts",
    "test:backend": "python -m pytest apps/backend/tests",
    "build:web": "vite build --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/node": "^24.6.1",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^3.2.4",
    "zod": "^4.1.11"
  }
}
